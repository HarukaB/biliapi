# Optional video used by integration tests.
# Defaults to BV1xx411c7mD when unset.
BILIAPI_TEST_BVID=BV1xx411c7mD

# Optional comma-separated av ids used by integration tests.
# Defaults to av1700001 when unset.
BILIAPI_TEST_AIDS=1700001

# Optional favorite folder media id used by integration tests.
# Defaults to 2519150301 when unset.
BILIAPI_TEST_FAV_ID=2519150301

# Preferred: provide credentials as one JSON object matching biliapi.Credentials.
# Minimum useful JSON for logged-in read APIs:
# {"SESSDATA":"..."}
# Minimum useful JSON for write/request-skeleton APIs:
# {"SESSDATA":"...","bili_jct":"..."}
# Leave empty to use the split fields below.
BILIAPI_CREDENTIALS_JSON=

# Required for logged-in read APIs and credential integration tests.
BILIAPI_SESSDATA=

# Required only for write/request-skeleton APIs that need CSRF.
BILIAPI_BILI_JCT=

# Recommended when you want the jar to look closer to a browser session.
# Most current read tests do not require them if SESSDATA is valid.
BILIAPI_DEDE_USER_ID=
BILIAPI_DEDE_USER_ID_CKMD5=
BILIAPI_SID=

# Currently not used by the client because QR login / cookie refresh is not implemented yet.
BILIAPI_REFRESH_TOKEN=
